MATRIX_HOMESERVER=https://matrix.example.com
MATRIX_USER=@roger:example.com
MATRIX_PASSWORD=changeme
# Comma-separated room IDs
ROOM_ALLOWLIST=!roomid:example.com
# Selects config/backends.<HOST_ROLE>.toml
HOST_ROLE=local
# Virtual key for LiteLLM gateway (not the raw Anthropic key)
GATEWAY_VKEY=sk-...
# Whisper-compatible transcription service for audio messages
SPEACHES_URL=http://srv:8000
